# Neo Configuration
# Copy this file to .env and fill in your values
#
# DEFAULT: OpenAI API (no extra configuration needed besides API key)
# OPTIONAL: Uncomment sections below to use Ollama instead of OpenAI

# =============================================================================
# DEFAULT: OpenAI API
# Just set your API key here - no other configuration needed
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here
NEO_MODEL=gpt-4o-mini

# =============================================================================
# OPTIONAL: Ollama Cloud (api.ollama.com) - requires real API key
# Uncomment these 3 lines to use Ollama Cloud instead of OpenAI:
# OPENAI_BASE_URL=https://api.ollama.com/v1
# OPENAI_API_KEY=your-ollama-api-key  # Get from https://ollama.com/settings
# NEO_MODEL=kimi-k2.5  # or any model available on Ollama Cloud

# =============================================================================
# OPTIONAL: Local/Custom Ollama Server - any API key string works
# Uncomment these 3 lines to use your own Ollama server:
# OPENAI_BASE_URL=http://localhost:11434/v1  # or your custom server URL
# OPENAI_API_KEY=ollama  # can be any string for local/remote Ollama
# NEO_MODEL=kimi-k2.5  # or whatever model you have in Ollama

# =============================================================================
# Optional Settings (work with both OpenAI and Ollama)

# Auto-confirm edits without prompting (default: false)
NEO_AUTO_CONFIRM=false

# Mock mode for testing without API key (default: false)
NEO_MOCK=false
